# Copy to .env and fill in for your environment.
#
# For multi-instance / multi-host (AWS EC2 etc.) deployments, REDIS_URL and
# KAFKA_BROKERS must point to a SHARED Redis/Kafka reachable from every
# instance — not localhost. See README "Horizontal Scaling" section.

NODE_ENV=production
PORT=3001

# Redis — shared across all instances (e.g. ElastiCache endpoint, or a
# dedicated Redis host's private IP). Used by RedisIoAdapter for cross-instance
# Socket.IO broadcast and by RedisService for sessions/state.
REDIS_URL=redis://<redis-host>:6379

# Kafka — shared cluster, comma-separated broker private IPs/DNS.
KAFKA_BROKERS=<kafka-broker-host>:9092

# Used by docker-compose.yml's KAFKA_ADVERTISED_LISTENERS — set this to the
# infra EC2's private IP (same value as <kafka-broker-host> above) so
# clients on other hosts can connect after the initial handshake. Leave as
# "localhost" for single-host dev.
KAFKA_ADVERTISED_HOST=localhost

# Frontend origin allowed for CORS / Socket.IO
FE_URL=https://your-frontend-domain.com

# File storage
UPLOAD_DIR=/var/uploads
MAX_FILE_SIZE_MB=5

# Session
SESSION_TTL_SECONDS=86400

{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/funni-bippi-be/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/funni-bippi-be/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/funni-bippi-be",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "chat-service": {
      "type": "application",
      "root": "apps/chat-service",
      "entryFile": "main",
      "sourceRoot": "apps/chat-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/chat-service/tsconfig.app.json"
      }
    },
    "funni-bippi-be": {
      "type": "application",
      "root": "apps/funni-bippi-be",
      "entryFile": "main",
      "sourceRoot": "apps/funni-bippi-be/src",
      "compilerOptions": {
        "tsConfigPath": "apps/funni-bippi-be/tsconfig.app.json"
      }
    },
    "matching-service": {
      "type": "application",
      "root": "apps/matching-service",
      "entryFile": "main",
      "sourceRoot": "apps/matching-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/matching-service/tsconfig.app.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    }
  }
}
